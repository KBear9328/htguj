<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full page background shown during page→panel transition -->
    <ImageView android:id="@+id/iv_full_page"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:scaleType="fitCenter" android:alpha="0"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Golden highlight overlay on full page showing active panel -->
    <com.example.mangareader.ui.PanelHighlightView android:id="@+id/panel_highlight_view"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Animated panel: draws static base image + per-region character/motion animations -->
    <com.example.mangareader.ui.AnimatedPanelView android:id="@+id/animated_panel_view"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <!-- OCR subtitle text -->
    <TextView android:id="@+id/tv_subtitle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_margin="16dp" android:layout_marginBottom="8dp"
        android:padding="10dp" android:background="#CC000000"
        android:textColor="#FFFFFF" android:textSize="14sp"
        android:lineSpacingMultiplier="1.3" android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/layout_bottom_bar"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <!-- End of manga message -->
    <TextView android:id="@+id/tv_end_message"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="📖 End of Manga" android:textColor="#FFFFFF"
        android:textSize="22sp" android:textStyle="bold"
        android:background="#99000000" android:padding="20dp" android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <!-- TOP BAR -->
    <LinearLayout android:id="@+id/layout_top_bar"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="8dp" android:paddingEnd="16dp"
        android:background="#CC000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">

        <ImageButton android:id="@+id/btn_back"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"/>

        <ImageView android:id="@+id/iv_page_thumb"
            android:layout_width="32dp" android:layout_height="44dp"
            android:layout_marginStart="4dp" android:scaleType="fitCenter"
            android:background="#333333"/>

        <TextView android:id="@+id/tv_page_indicator"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="12dp"
            android:text="1 / 1" android:textColor="#FFFFFF"
            android:textSize="15sp" android:textStyle="bold"/>

        <TextView android:id="@+id/tv_panel_indicator"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Panel 1/1" android:textColor="#AAAAAA" android:textSize="12sp"/>
    </LinearLayout>

    <!-- BOTTOM BAR -->
    <LinearLayout android:id="@+id/layout_bottom_bar"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="#CC000000" android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">

        <SeekBar android:id="@+id/seek_bar_page"
            android:layout_width="match_parent" android:layout_height="32dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:progressTint="#E63946" android:thumbTint="#E63946"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center">

            <com.google.android.material.button.MaterialButton android:id="@+id/btn_prev"
                android:layout_width="56dp" android:layout_height="56dp"
                android:text="◀" android:textSize="18sp"
                app:cornerRadius="28dp" app:backgroundTint="#333333"
                android:layout_marginEnd="16dp"/>

            <com.google.android.material.button.MaterialButton android:id="@+id/btn_play_pause"
                android:layout_width="64dp" android:layout_height="64dp"
                android:text="▶" android:textSize="24sp"
                app:cornerRadius="32dp" app:backgroundTint="#E63946"
                android:layout_marginEnd="16dp"/>

            <com.google.android.material.button.MaterialButton android:id="@+id/btn_next"
                android:layout_width="56dp" android:layout_height="56dp"
                android:text="▶" android:textSize="18sp"
                app:cornerRadius="28dp" app:backgroundTint="#333333"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔊 Speed" android:textColor="#888888"
                android:textSize="12sp" android:layout_marginEnd="8dp"/>

            <com.google.android.material.slider.Slider android:id="@+id/slider_speech_rate"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0.5" android:valueTo="2.0"
                android:value="0.9" android:stepSize="0.1"
                app:thumbColor="#E63946" app:trackColorActive="#E63946"
                app:trackColorInactive="#444444"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
